# Eq1 provider selection (default: opencode_internal_fallback)
EQ1_PROVIDER=opencode_internal_fallback

# Eq1 internal (OpenCode agent) primary
# EQ1_INTERNAL_BASE_URL=http://127.0.0.1:4996
# EQ1_INTERNAL_AGENT=eq1-core
# EQ1_INTERNAL_MODEL=openai/gpt-5.3-codex-spark
# EQ1_INTERNAL_SESSION_TITLE=eq1-internal

# Eq1 external fallback provider (used when EQ1_PROVIDER=opencode_internal_fallback)
# EQ1_FALLBACK_PROVIDER=cerebras

# 1st priority: Cerebras
CEREBRAS_API_KEY=replace-with-your-cerebras-key
CEREBRAS_MODEL=gpt-oss-120b
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# 2nd option: Groq
# GROQ_API_KEY=replace-with-your-groq-key
# GROQ_MODEL=openai/gpt-oss-20b
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Generic OpenAI-compatible override (optional)
# EQ1_BASE_URL=
# EQ1_API_KEY=
# EQ1_MODEL=

# Logging (optional: debug | info | warn | error)
# LOG_LEVEL=info
# OPENCODE_LOG_FILE=/srv/opencode/data/logs/runtime.log

# ------------------------------------------------------------
# Devserver runtime controls (optional)
# ------------------------------------------------------------

# Project root path used by dev-up/dev-doctor/dev-smoke.
# Default: parent of .devserver (..)
# X_OC_PROJECT_DIR=..

# Host ports
# X_OC_PODMAN_HOST_PORT=4996
# X_OC_PODMAN_CONTAINER_OPENCODE_PORT=4996
# X_OC_PODMAN_OPENCODE_PORT=4996  # shortcut for both host/container
# X_OC_PODMAN_DASHBOARD_ENABLED=0
# X_OC_PODMAN_DASHBOARD_HOST_PORT=51234
# X_OC_PODMAN_DASHBOARD_INTERNAL_HOST_PORT=51235
# OPENCODE_DASHBOARD_PACKAGE=

# Podman behavior
# X_OC_PODMAN_EXCLUDE_DEVSERVER=1
# X_OC_PODMAN_FORCE_KILL_PORTS=0
# X_OC_PODMAN_TTY=1
# X_OC_PODMAN_X1_ENABLED=1
# X_OC_PODMAN_X1_MODE=both
# X_OC_PODMAN_X1_MODE=poller
# X_OC_PODMAN_X1_MODE=direct
# X_OC_PODMAN_X3_ENABLED=1
# X_OC_PODMAN_BASE_URL=http://127.0.0.1:4996
# X_OC_PODMAN_RUNTIME_SCRIPT=/opt/opencode/src/index.ts
# X_OC_PODMAN_X1_WEBHOOK_HOST_PORT=5100
# X_OC_PODMAN_X1_WEBHOOK_PATH=/webhook
# X_OC_PODMAN_X1_WEBHOOK_SOURCE=x1_telegram
# X_OC_PODMAN_X1_WEBHOOK_TASK_SOURCE=x1_telegram
# X_OC_PODMAN_X1_POLLER_SOURCE=x1_telegram
# X_OC_PODMAN_X1_POLLER_TASK_SOURCE=x1_telegram
# X_OC_PODMAN_X1_POLLER_ALLOWED_USER_IDS=5689387562
# X_OC_PODMAN_X1_POLLER_POLL_INTERVAL_MS=1000
# X_OC_PODMAN_X1_POLLER_POLL_TIMEOUT_SEC=25
# X_OC_PODMAN_X1_POLLER_POLL_LIMIT=100
# X_OC_PODMAN_X1_POLLER_API_BASE=https://api.telegram.org
# X_OC_PODMAN_X1_POLLER_TOKEN=8701...
# X_OC_PODMAN_X1_BOT_TOKEN=8701...
# X_OC_PODMAN_X1_DIRECT_SOURCE=x1_chatbot
# X_OC_PODMAN_X1_DIRECT_AGENT=spark
# X_OC_PODMAN_X1_DIRECT_BASE_URL=http://127.0.0.1:4996
# X_OC_PODMAN_X1_DIRECT_SESSION_MODE=per-chat
# X_OC_PODMAN_X1_DIRECT_TOKEN=8701...
# CONTROL_PLANE_OPENCODE_BASE_URL=  # Optional override for control-plane default registry
# (empty => direct channel disabled even in X1_MODE=both)
# X_OC_PODMAN_X1_DIRECT_ALLOWED_USER_IDS=5689387562
# X_OC_PODMAN_X1_DIRECT_POLL_INTERVAL_MS=1000
# X_OC_PODMAN_X1_DIRECT_POLL_TIMEOUT_SEC=25
# X_OC_PODMAN_X1_DIRECT_POLL_LIMIT=100
# X_OC_PODMAN_X1_DIRECT_API_BASE=https://api.telegram.org
# X_OC_PODMAN_X1_DIRECT_SYSTEM=
#
# X_OC_PODMAN_X2_TELEGRAM_REPORT=1
# X_OC_PODMAN_X2_SUMMARIZER_AGENT=x2-summarizer
# X_OC_PODMAN_X4_SUMMARIZER_AGENT=x4-summarizer
# X_OC_PODMAN_X2_AGENT_ROUTING=auto
# X_OC_PODMAN_X2_SIMPLE_AGENT=joshua
# X_OC_PODMAN_X2_COMPLEX_AGENT=joshua
# X_OC_PODMAN_X2_BYPASS_AGENT=
# X_OC_PODMAN_X2_BYPASS_MODEL=
# X2_SUMMARIZER_AGENT=x2-summarizer
# X4_SUMMARIZER_AGENT=x4-summarizer
# X_OC_PODMAN_SPARK_PROMPT_SOURCE_HOST=.devserver/agents/spark.prompt.txt
# X_OC_PODMAN_GENESIS_PROMPT_SOURCE_HOST=.devserver/agents/genesis.prompt.txt
# X_OC_PODMAN_MOSES_PROMPT_SOURCE_HOST=.devserver/agents/moses.prompt.txt
# X_OC_PODMAN_JOSHUA_PROMPT_SOURCE_HOST=.devserver/agents/joshua.prompt.txt
# X_OC_PODMAN_BEZALEL_PROMPT_SOURCE_HOST=.devserver/agents/bezalel.prompt.txt
# X_OC_PODMAN_OHOLIAB_PROMPT_SOURCE_HOST=.devserver/agents/oholiab.prompt.txt
# X_OC_PODMAN_AARON_PROMPT_SOURCE_HOST=.devserver/agents/aaron.prompt.txt
# X_OC_PODMAN_CALEB_PROMPT_SOURCE_HOST=.devserver/agents/caleb.prompt.txt
# X_OC_PODMAN_EQ1_CORE_PROMPT_SOURCE_HOST=.devserver/agents/eq1-core.prompt.txt
# X_OC_PODMAN_X2_SUMMARIZER_PROMPT_SOURCE_HOST=.devserver/agents/x2-summarizer.prompt.txt
# X_OC_PODMAN_X4_SUMMARIZER_PROMPT_SOURCE_HOST=.devserver/agents/x4-summarizer.prompt.txt
# X_OC_PODMAN_DOC_TEMPLATES_SOURCE_HOST=.devserver/run-sync/templates
# X_OC_PODMAN_DOC_TEMPLATES_IMPORT_MODE=always
# X_OC_PODMAN_X3_INTERVAL_MS=3000
# X_OC_PODMAN_X3_MAX_PROCESS=10

# Run-sync seed directory (default: .devserver/run-sync)
# X_OC_PODMAN_RUN_SYNC_DIR=
# X_OC_PODMAN_AUTH_SOURCE_HOST=
# X_OC_PODMAN_OPENCODE_CONFIG_SOURCE_HOST=

# Startup readiness and smoke timings (ms)
# X_OC_PODMAN_READY_TIMEOUT_MS=30000
# X_OC_PODMAN_READY_INTERVAL_MS=500
# X_OC_PODMAN_SMOKE_TIMEOUT_MS=45000
# X_OC_PODMAN_SMOKE_INTERVAL_MS=500

# Optional warnings/checks
# X_OC_WARN_PROVIDER_KEYS=0
# X_OC_DOCTOR_CHECK_PROVIDER_KEYS=0

# Seed sync behavior
# X_OC_PODMAN_OPENCODE_CONFIG_IMPORT_MODE=always
# X_OC_PODMAN_AUTH_IMPORT_MODE=always

# Optional webhook/automation credentials
# X1_WEBHOOK_SECRET=
# OPENCODE_X1_WEBHOOK_SECRET=

# Telegram polling ingress (default: poller)
# TELEGRAM_BOT_TOKEN=
# ALLOWED_USER_IDS=
# POLLING_INTERVAL_MS=1000
# OPENCODE_X1_BOT_TOKEN
