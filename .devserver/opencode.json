{
    "$schema": "https://opencode.ai/config.json",
    "plugin": ["oh-my-opencode@latest"],
    "instructions": ["AGENTS.md", "rules/*.md"],
    "agent": {
        "spark": {
            "mode": "primary",
            "model": "openai/gpt-5.3-codex-spark",
            "variant": "xhigh",
            "prompt": "{file:/run/opencode-seed/agents/spark.prompt.txt}",
            "tools": {
                "write": true,
                "edit": true,
                "bash": true
            }
        },
        "eq1-core": {
            "mode": "primary",
            "model": "openai/gpt-5.3-codex-spark",
            "variant": "xhigh",
            "prompt": "{file:/run/opencode-seed/agents/eq1-core.prompt.txt}",
            "tools": {
                "write": false,
                "edit": false,
                "bash": false
            }
        },
        "x2-summarizer": {
            "mode": "primary",
            "model": "openai/gpt-5.3-codex-spark",
            "variant": "xhigh",
            "prompt": "{file:/run/opencode-seed/agents/x2-summarizer.prompt.txt}",
            "tools": {
                "write": true,
                "edit": true,
                "bash": true
            }
        },
        "x4-summarizer": {
            "mode": "primary",
            "model": "openai/gpt-5.3-codex-spark",
            "variant": "xhigh",
            "prompt": "{file:/run/opencode-seed/agents/x4-summarizer.prompt.txt}",
            "tools": {
                "write": true,
                "edit": true,
                "bash": true
            }
        },
        "genesis": {
            "mode": "primary",
            "model": "openai/gpt-5.2",
            "variant": "xhigh",
            "prompt": "{file:/run/opencode-seed/agents/genesis.prompt.txt}",
            "tools": {
                "write": true,
                "edit": true,
                "bash": false,
                "ask": true
            }
        },
        "spark-subagent": {
            "mode": "subagent",
            "model": "openai/gpt-5.3-codex-spark",
            "variant": "xhigh",
            "prompt": "{file:/run/opencode-seed/agents/spark.prompt.txt}",
            "tools": {
                "write": true,
                "edit": true,
                "bash": true
            }
        }
    },
    "permission": {
        "read": {
            "*": "deny",
            "/workspace/project/**": "allow",
            "/workspace/project/.devserver/**": "deny",
            ".devserver/**": "deny"
        },
        "edit": {
            "*": "deny",
            "/workspace/project/**": "allow",
            "/workspace/project/.devserver/**": "deny",
            ".devserver/**": "deny"
        },
        "glob": {
            "*": "deny",
            "/workspace/project/**": "allow",
            "/workspace/project/.devserver/**": "deny",
            ".devserver/**": "deny"
        },
        "grep": {
            "*": "deny",
            "/workspace/project/**": "allow",
            "/workspace/project/.devserver/**": "deny",
            ".devserver/**": "deny"
        },
        "list": {
            "*": "deny",
            "/workspace/project/**": "allow",
            "/workspace/project/.devserver/**": "deny",
            ".devserver/**": "deny"
        },
        "bash": {
            "*": "ask",
            "*.devserver*": "deny"
        },
        "external_directory": {
            "*": "deny",
            "/workspace/project/**": "allow",
            "/workspace/project/.devserver/**": "deny"
        }
    },
    "watcher": {
        "ignore": [".devserver/**"]
    },
    "server": {
        "port": 4996,
        "hostname": "127.0.0.1"
    }
}
