{
    "$schema": "https://opencode.ai/config.json",
    "instructions": ["docs/AGENTS.md", "rules/*.md"],
    "agent": {
        "spark": {
            "description": "Default execution agent for fast, practical coding tasks.",
            "mode": "primary",
            "model": "openai/gpt-5.3-codex-spark",
            "variant": "xhigh",
            "prompt": "{file:/run/opencode-seed/agents/spark.prompt.txt}",

            "temperature": 0.25
        },
        "eq1-core": {
            "description": "Read-focused core agent for classification, evaluation, and summarization.",
            "mode": "primary",
            "model": "openai/gpt-5.3-codex-spark",
            "variant": "xhigh",
            "prompt": "{file:/run/opencode-seed/agents/eq1-core.prompt.txt}",

            "temperature": 0.05
        },
        "x2-summarizer": {
            "description": "Agent that structures and summarizes X2 execution results.",
            "mode": "primary",
            "model": "openai/gpt-5.3-codex-spark",
            "variant": "xhigh",
            "prompt": "{file:/run/opencode-seed/agents/x2-summarizer.prompt.txt}",

            "temperature": 0.15
        },
        "x4-summarizer": {
            "description": "Agent that summarizes and enriches context for X4 routing decisions.",

            "mode": "primary",
            "model": "openai/gpt-5.3-codex-spark",
            "variant": "xhigh",
            "prompt": "{file:/run/opencode-seed/agents/x4-summarizer.prompt.txt}",

            "temperature": 0.15
        },
        "genesis": {
            "description": "Creator of the system SSOT based on the HOMSA framework.",
            "mode": "primary",
            "model": "openai/gpt-5.3-codex",
            "variant": "xhigh",
            "temperature": 0.2,
            "color": "accent",
            "prompt": "{file:/run/opencode-seed/agents/genesis.prompt.txt}"
        },
        "moses": {
            "description": "Guardian and algebraic evolver of the system architecture (AGENTS.md).",
            "mode": "primary",
            "model": "openai/gpt-5.3-codex",
            "variant": "high",
            "temperature": 0.2,
            "color": "info",
            "prompt": "{file:/run/opencode-seed/agents/moses.prompt.txt}",
            "permission": {
                "task": {
                    "*": "allow"
                },
                "bash": {
                    "*": "allow"
                }
            },
            "steps": 99
        },
        "joshua": {
            "description": "Technical PM managing TODOs and dispatching coding tasks to Bezalel/Oholiab.",
            "mode": "primary",
            "model": "openai/gpt-5.2",
            "variant": "high",
            "temperature": 0.1,
            "color": "primary",
            "prompt": "{file:/run/opencode-seed/agents/joshua.prompt.txt}",
            "permission": {
                "task": {
                    "*": "deny",
                    "bezalel": "allow",
                    "oholiab": "allow",
                    "aaron": "allow",
                    "caleb": "allow"
                },
                "bash": {
                    "*": "allow"
                }
            },
            "steps": 50
        },
        "bezalel": {
            "description": "Execution coder implementing and testing tasks from the TODO list.",
            "mode": "subagent",
            "model": "openai/gpt-5.3-codex-spark",
            "variant": "xhigh",
            "temperature": 0.2,
            "color": "warning",
            "prompt": "{file:/run/opencode-seed/agents/bezalel.prompt.txt}",
            "steps": 99
        },
        "oholiab": {
            "description": "Elite Principal Engineer responsible for implementing highly complex core logic and resolving deep bugs.",
            "mode": "subagent",
            "model": "openai/gpt-5.3-codex",
            "variant": "xhigh",
            "temperature": 0.1,
            "color": "error",
            "prompt": "{file:/run/opencode-seed/agents/oholiab.prompt.txt}",
            "steps": 99
        },
        "aaron": {
            "description": "Chief QA & Code Reviewer enforcing HOMSA compliance and security.",
            "mode": "subagent",
            "model": "openai/gpt-5.3-codex",
            "variant": "xhigh",
            "temperature": 0.0,
            "color": "success",
            "prompt": "{file:/run/opencode-seed/agents/aaron.prompt.txt}",
            "tools": {
                "write": false,
                "edit": false,
                "bash": true,
                "ask": false
            }
        },
        "caleb": {
            "description": "Read-only codebase scout and explorer dispatched by Joshua for pre-task reconnaissance.",
            "mode": "subagent",
            "model": "openai/gpt-5.3-codex-spark",
            "variant": "xhigh",
            "temperature": 0.1,
            "color": "info",
            "prompt": "{file:/run/opencode-seed/agents/caleb.prompt.txt}",
            "tools": {
                "write": false,
                "edit": false,
                "bash": true,
                "ask": false
            }
        },

        "spark-subagent": {
            "description": "Subagent variant of Spark for delegated coding execution.",
            "mode": "subagent",
            "model": "openai/gpt-5.3-codex-spark",
            "variant": "xhigh",
            "prompt": "{file:/run/opencode-seed/agents/spark.prompt.txt}"
        }
    },
    "permission": {
        "read": {
            "*": "allow"
        },
        "edit": {
            "*": "allow"
        },
        "glob": {
            "*": "allow"
        },
        "grep": {
            "*": "allow"
        },
        "list": {
            "*": "allow"
        },
        "bash": {
            "*": "allow",
            "rm *": "deny",
            "rm -rf *": "deny",
            "git commit *": "deny",
            "git push *": "deny",
            "git reset *": "deny",
            "git rebase *": "deny",
            "git merge *": "deny",
            "git checkout *": "deny"
        },
        "external_directory": {
            "*": "allow"
        }
    },
    "watcher": {
        "ignore": [".devserver/**"]
    },
    "server": {
        "port": 4996,
        "hostname": "127.0.0.1"
    }
}
